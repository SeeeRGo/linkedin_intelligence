{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "canonical_id",
    "content_type",
    "language",
    "author_type",
    "author_score",
    "post_score",
    "comment_score",
    "discussion_value",
    "strategic_interaction_potential",
    "recommended_action",
    "relevance_tags",
    "low_value_flags",
    "emerging_themes",
    "why_relevant",
    "key_thesis",
    "rationale",
    "confidence"
  ],
  "properties": {
    "canonical_id": {
      "type": "string",
      "description": "Stable ID for the analyzed post or comment."
    },
    "content_type": {
      "type": "string",
      "enum": ["post", "comment", "post_with_comments"]
    },
    "language": {
      "type": "string",
      "enum": ["en", "it", "fr", "es", "other", "unknown"]
    },
    "author_type": {
      "type": "string",
      "enum": ["thinker", "interpreter_connector", "operator", "promoter", "unknown"]
    },
    "author_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "post_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "comment_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "discussion_value": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "strategic_interaction_potential": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "recommended_action": {
      "type": "string",
      "enum": ["follow", "connect", "comment", "monitor", "quote_post_candidate", "ignore"]
    },
    "relevance_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "merchandising",
          "assortment_planning",
          "retail_transformation",
          "editorial_retail",
          "experiential_retail",
          "luxury_retail",
          "clienteling",
          "customer_decision_making",
          "subjective_decision_layer",
          "mismatch",
          "blind_spots",
          "retail_intelligence",
          "industry_evolution",
          "low_value"
        ]
      }
    },
    "low_value_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
        "generic_trend_report",
        "outfit_only",
        "motivational",
        "hiring_spam",
        "generic_ai_hype",
        "buzzword_salad",
        "pure_kpi_optimization",
        "shallow_luxury_commentary",
        "product_promotion",
        "none"
      ]
      }
    },
    "emerging_themes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "why_relevant": {
      "type": "string"
    },
    "key_thesis": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
